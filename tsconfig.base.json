{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": false,
    "baseUrl": ".",
    "paths": {
      "@firefox-cli/cli": ["packages/cli/src/index.ts"],
      "@firefox-cli/native-host": ["packages/native-host/src/index.ts"],
      "@firefox-cli/protocol": ["packages/protocol/src/index.ts"],
      "@firefox-cli/test-support": ["packages/test-support/src/index.ts"]
    },
    "types": ["node"],
    "allowJs": false,
    "noFallthroughCasesInSwitch": true
  }
}
