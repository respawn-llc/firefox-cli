{
  "name": "firefox-cli-workspace",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=22.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@firefox-cli/cli": "workspace:*",
    "@firefox-cli/native-host": "workspace:*",
    "@firefox-cli/protocol": "workspace:*",
    "@firefox-cli/test-support": "workspace:*"
  },
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format .",
    "deps:policy": "node ./scripts/check-dependency-policy.mjs",
    "ts:policy": "node ./scripts/check-typescript-policy.mjs",
    "test:policy": "node --test ./scripts/check-dependency-policy.test.mjs ./scripts/check-eslint-firefox-cli-plugin.test.mjs ./scripts/check-eslint-policy.test.mjs ./scripts/check-firefox-architecture-policy.test.mjs ./scripts/check-typescript-config-policy.test.mjs ./scripts/check-typescript-policy.test.mjs",
    "version:sync": "bun scripts/sync-version.ts",
    "version:check": "bun scripts/sync-version.ts --check",
    "release:prepare-version": "bun scripts/prepare-release-version.ts",
    "lint:biome": "biome lint .",
    "lint:eslint": "eslint .",
    "lint": "bun run deps:policy && bun run ts:policy && bun run lint:biome && bun run lint:eslint",
    "source:size": "bun scripts/source-size-check.ts",
    "tsc": "node ./node_modules/@typescript/native/bin/tsc",
    "typecheck": "bun run tsc -- -b --pretty false --noEmit",
    "test": "bun run deps:policy && bun run ts:policy && bun run test:policy && vitest run --exclude \"scripts/check-*.test.mjs\"",
    "test:e2e": "bun run build && bun scripts/e2e-phase2.ts && bun scripts/e2e-disposable-firefox.ts",
    "extension:build": "bun scripts/build-extension.ts && bun scripts/copy-extension-assets.ts && bun scripts/build-extension-archive.ts",
    "extension:lint": "bun run extension:build && web-ext lint --self-hosted --source-dir dist/extension",
    "extension:run": "bun run extension:build && web-ext run --source-dir dist/extension",
    "extension:sign": "bun run extension:build && bun scripts/sign-extension.ts",
    "build:binary": "bun scripts/build-binary.ts",
    "build:binary:all": "bun scripts/build-all-binaries.ts",
    "build:artifacts": "bun run build:binary && bun run extension:build && bun run package",
    "build:artifacts:check": "bun run build:artifacts && bun run package:verify",
    "build:packages": "bun run typecheck",
    "build": "bun run version:check && bun run deps:policy && bun run ts:policy && bun run build:packages && bun run build:artifacts",
    "package": "bun scripts/package.ts",
    "package:verify": "bun scripts/package-check.ts",
    "npm:package": "bun scripts/npm-package.ts",
    "npm:package:verify": "bun scripts/npm-package-check.ts",
    "package:check": "bun run build && bun run package:verify",
    "npm:publish:local": "bun scripts/npm-publish.ts --build-all",
    "npm:publish:ci": "bun scripts/npm-publish.ts --build-all --require-signed-xpi --provenance",
    "npm:publish:dry-run": "bun scripts/npm-publish.ts --build-all --dry-run",
    "deps:check": "bun scripts/dependency-upgrade-check.ts",
    "release:check": "bun run build && bun scripts/release-check.ts",
    "release:check:local": "bun run build && bun scripts/release-check.ts --allow-unsigned-local",
    "release:check:signed": "bun run build && bun scripts/release-check.ts --require-signed-xpi",
    "ci": "bun run format:check && bun run version:check && bun run lint && bun run source:size && bun run typecheck && bun run test && bun run build && bun run extension:lint && bun run package:verify",
    "check": "bun run ci"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "web-ext": "^10.4.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "js-yaml": "4.3.0",
    "shell-quote": "1.9.0",
    "undici": "7.28.0"
  }
}
